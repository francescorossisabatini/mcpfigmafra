{
  "_comment": "Design tokens for My Secret Garden – source of truth: src/index.css :root variables",
  "_source": "https://github.com/francescorossisabatini/mysecregardenrestaurantcafe",

  "color": {
    "_comment": "All HEX values converted from HSL variables in src/index.css :root",

    "background": {
      "_comment": "Page and surface backgrounds",
      "primary":  "#F8F6F1",
      "card":     "#FAF8F4",
      "muted":    "#F4F1EB",
      "secondary":"#F2EDE3"
    },

    "text": {
      "_comment": "Body copy, headings, secondary labels",
      "primary":   "#1A1A1A",
      "muted":     "#474747"
    },

    "brand": {
      "_comment": "Core brand palette – primary is the deep spiritual blue, accent is the natural green",
      "primary":      "#243260",
      "accent":       "#3D661A",
      "accentLight":  "#A2C572",
      "blue":         "#1173D4",
      "cream":        "#F7F4ED"
    },

    "border": {
      "_comment": "Borders, dividers, and input outlines",
      "default":   "#E0DBD1",
      "input":     "#E0DBD1",
      "ring":      "#243260",
      "focusRing": "#2E4EB8"
    },

    "state": {
      "_comment": "Semantic badge colors. vegan/glutenFree/bio are hardcoded in MenuSection – see audit.",
      "vegan":      "#166534",
      "glutenFree": "#92400E",
      "bio":        "#065F46"
    },

    "semantic": {
      "_comment": "System feedback colors",
      "destructive": "#D31212",
      "warning":     "#F59F0A",
      "success":     "#3D661A"
    },

    "dark": {
      "_comment": "Dark mode equivalents (.dark class on <html>)",
      "background":  "#141929",
      "card":        "#1B2232",
      "foreground":  "#F0EDE6",
      "primary":     "#667ECC",
      "accent":      "#90C95E",
      "accentLight": "#ACCE7E",
      "blue":        "#6CADEF",
      "destructive": "#DC3C3C",
      "border":      "#364159"
    },

    "gradient": {
      "_comment": "Used in hero and green-section backgrounds. Values are CSS linear-gradient strings.",
      "hero":   "linear-gradient(135deg, #243260 0%, #3C517C 100%)",
      "green":  "linear-gradient(135deg, #5E8C35 0%, #88B54A 100%)",
      "subtle": "linear-gradient(180deg, #FAF8F4 0%, #EFF4E9 100%)"
    }
  },

  "_dynamic": {
    "_comment": "These tokens cannot be resolved to a static HEX value — they are set via CSS custom properties that may be overridden at runtime or vary between light/dark mode. They cannot be imported into Tokens Studio. Document their visual appearance manually in Figma. Light-mode reference: daily=#FFF2C2, dailyAlt=#F2F7E8, klassiker=#F8F6F1, badgeWood=#604D2E",
    "daily":     "hsl(var(--daily-card))",
    "dailyAlt":  "hsl(var(--daily-card-alt))",
    "klassiker": "hsl(var(--klassiker-card))",
    "badgeWood": "hsl(var(--badge-wood))"
  },

  "typography": {
    "_comment": "Font families, scale, weight, and spacing tokens",

    "family": {
      "_comment": "display = handwritten headings (h1–h6 by default in index.css), body = editorial serif, ui = clean sans",
      "display": "Caveat, cursive",
      "body":    "Lora, Georgia, 'Times New Roman', serif",
      "accent":  "'Cormorant Garamond', Georgia, serif",
      "ui":      "'Work Sans', system-ui, sans-serif"
    },

    "scale": {
      "_comment": "Standard Tailwind scale – base is 16px (1rem)",
      "xs":   "0.75rem",
      "sm":   "0.875rem",
      "base": "1rem",
      "lg":   "1.125rem",
      "xl":   "1.25rem",
      "2xl":  "1.5rem",
      "3xl":  "1.875rem",
      "4xl":  "2.25rem",
      "5xl":  "3rem",
      "6xl":  "3.75rem"
    },

    "weight": {
      "regular":  "400",
      "medium":   "500",
      "semibold": "600",
      "bold":     "700"
    },

    "lineHeight": {
      "tight":   "1.25",
      "normal":  "1.5",
      "relaxed": "1.75"
    },

    "letterSpacing": {
      "tight":  "-0.025em",
      "normal": "0em",
      "wide":   "0.05em",
      "wider":  "0.1em"
    }
  },

  "spacing": {
    "_comment": "Standard Tailwind 4px base grid. All values in rem.",
    "1":  "0.25rem",
    "2":  "0.5rem",
    "3":  "0.75rem",
    "4":  "1rem",
    "6":  "1.5rem",
    "8":  "2rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem",
    "32": "8rem"
  },

  "radius": {
    "_comment": "Base --radius: 0.5rem. sm/md/lg/xl derive from it via calc() in tailwind.config.",
    "sm":   "0.25rem",
    "md":   "0.375rem",
    "lg":   "0.5rem",
    "xl":   "0.75rem",
    "2xl":  "1rem",
    "full": "9999px"
  },

  "shadow": {
    "_comment": "From --shadow-* variables in src/index.css",
    "sm": "0 2px 12px -2px rgba(0,0,0,0.08)",
    "md": "0 4px 20px -4px rgba(62,122,51,0.15)",
    "lg": "0 10px 40px -10px rgba(36,50,96,0.25)"
  },

  "animation": {
    "_comment": "Durations and easings used in keyframe animations defined in tailwind.config.ts",
    "duration": {
      "fast":   "200ms",
      "normal": "500ms",
      "slow":   "800ms",
      "float":  "3000ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in":      "cubic-bezier(0.4, 0, 1, 1)",
      "out":     "cubic-bezier(0, 0, 0.2, 1)",
      "inOut":   "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "keyframes": {
      "accordionDown": "accordion-down",
      "accordionUp":   "accordion-up",
      "fadeIn":        "fade-in",
      "fadeInHero":    "fade-in-hero",
      "slideUp":       "slide-up",
      "float":         "float"
    }
  },

  "breakpoint": {
    "_comment": "2xl is custom at 1400px (container max-width). All others are standard Tailwind.",
    "sm":  "640px",
    "md":  "768px",
    "lg":  "1024px",
    "xl":  "1280px",
    "2xl": "1400px"
  },

  "zIndex": {
    "_comment": "Standard layering for sticky elements, overlays, and modals",
    "base":    "0",
    "sticky":  "100",
    "overlay": "200",
    "modal":   "300",
    "toast":   "400"
  }
}
